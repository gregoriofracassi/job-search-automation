# Local development (apps run on host, infra runs in Docker via docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/job_search
REDIS_URL=redis://localhost:6381

# NOTE: for production (docker-compose.prod.yml) these are overridden in the
# compose file to use Docker service hostnames (postgres, redis) instead of localhost.

JWT_SECRET=change-me-in-production
JWKS_URI=http://localhost:3000/idp/.well-known/jwks.json
OIDC_COOKIE_KEYS=change-me-in-production
PORT=3000
NODE_ENV=development

# Apify — get your token at https://console.apify.com/account/integrations
APIFY_API_KEY=

# LLM Provider (for job evaluation and cover letter generation)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Scheduler (daily job scraping)
DAILY_SCRAPE_CRON=0 9 * * *
